LINKUS_BASE_URL=https://your-linkus-server/api/v1.0/
LINKUS_CLIENT_ID=replace-with-client-id
LINKUS_CLIENT_SECRET=replace-with-a-rotated-secret
# Legacy deployments may use LINKUS_API_SECRET instead of LINKUS_CLIENT_SECRET.
# LINKUS_API_SECRET=replace-with-a-rotated-secret
LINKUS_AUTH_HEADER=X-API-Secret
LINKUS_AUTH_PREFIX=
LINKUS_VERIFY_TLS=false
OPENAI_MODEL=gpt-5-mini
# Create a private replacement key and place it only in your local .env file.
OPENAI_API_KEY=

# To use OpenRouter instead of OpenAI, set AI_PROVIDER=openrouter
# and paste your OpenRouter key only in your local .env file.
AI_PROVIDER=openai
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_API_KEY=
PORT=4173
